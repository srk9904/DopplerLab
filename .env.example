# DopplerLab Environment Configuration
# Copy this to .env and adjust paths as needed

# Data root path (where neurips_v1/v2 folders are located)
DATA_ROOT="d:/Antigravity/DopplerLab/Datasets"

# Default dataset version ("v1" or "v2")
DATASET_VERSION="v2"

# Output directories
MODEL_ROOT="d:/Antigravity/DopplerLab/models"
RESULTS_ROOT="d:/Antigravity/DopplerLab/results"
LOG_ROOT="d:/Antigravity/DopplerLab/logs"
